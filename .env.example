# 飞书小说创作团队 Bot 环境变量配置
# 复制此文件为 .env 并填入实际值

# OpenCode API 地址（默认本地）
OPENCODE_API=http://localhost:8080

# ============ 主编 Bot ============
EDITOR_APP_ID=cli_xxxxxxxxxxxxx
EDITOR_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ============ 资料员 Bot ============
RESEARCHER_APP_ID=cli_xxxxxxxxxxxxx
RESEARCHER_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ============ 分析师 Bot ============
ANALYST_APP_ID=cli_xxxxxxxxxxxxx
ANALYST_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ============ 主笔 Bot ============
WRITER_APP_ID=cli_xxxxxxxxxxxxx
WRITER_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ============ 段子手 Bot ============
JOKESTER_APP_ID=cli_xxxxxxxxxxxxx
JOKESTER_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ============ 校对 Bot ============
PROOFREADER_APP_ID=cli_xxxxxxxxxxxxx
PROOFREADER_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ============ 设定师 Bot ============
WORLDBUILDER_APP_ID=cli_xxxxxxxxxxxxx
WORLDBUILDER_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ============ Bot Open IDs（主编调度用，可选） ============
# 不配置也能用，主编会在群里 @ 该 Bot 时自动学习
# RESEARCHER_OPEN_ID=ou_xxxxxxxxxxxxx
# ANALYST_OPEN_ID=ou_xxxxxxxxxxxxx
# WRITER_OPEN_ID=ou_xxxxxxxxxxxxx
# JOKESTER_OPEN_ID=ou_xxxxxxxxxxxxx
# PROOFREADER_OPEN_ID=ou_xxxxxxxxxxxxx
# WORLDBUILDER_OPEN_ID=ou_xxxxxxxxxxxxx